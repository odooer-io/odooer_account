<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Wire group_account_user ("Show Full Accounting Features") into group_account_manager.

        In CE alone, group_account_manager only implies group_account_invoice.
        group_account_user (which unlocks journal entries, financial reports, bank
        reconciliation, analytic accounts, etc.) is hidden and not auto-assigned to
        anyone.  Enterprise fixes this inside account_accountant; we replicate the
        behaviour here for our community accounting module.

        Result after install:
            group_account_manager
                └─ implies group_account_user
                        └─ implies group_account_basic  ──► group_account_invoice
                        └─ implies group_account_readonly

        Any user with Accounting ▸ Administrator will therefore automatically
        receive "Show Full Accounting Features", giving them access to:
          - Financial reports (P&L, Balance Sheet, …)
          - Bank reconciliation UI
          - Journal entries (account.move) full CRUD
          - Analytic accounts / plans
          - Lock-date configuration
    -->
    <record id="account.group_account_manager" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
    </record>

</odoo>
