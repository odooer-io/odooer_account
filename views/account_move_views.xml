<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_account_move_form_bank_rec_button" model="ir.ui.view">
        <field name="name">account.move.form.bank.rec.button</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_bank_rec"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-university"
                        invisible="bank_statement_line_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="bank_statement_line_count"/>
                        </span>
                        <span class="o_stat_text">Statement</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
