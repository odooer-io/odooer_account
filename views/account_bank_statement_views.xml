<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search view for account.bank.statement.line used by bank rec widget -->
    <record id="view_bank_statement_line_search" model="ir.ui.view">
        <field name="name">account.bank.statement.line.search.odooer</field>
        <field name="model">account.bank.statement.line</field>
        <field name="arch" type="xml">
            <search string="Search Transactions">
                <field name="name" string="Statement Line"/>
                <field name="payment_ref" string="Reference"/>
                <field name="partner_id" string="Partner"/>
                <field name="statement_id" string="Bank Statement"/>
                <field name="journal_id" string="Journal"/>
                <separator/>
                <filter name="filter_unreconciled" string="Unreconciled"
                    domain="[('is_reconciled','=',False)]"/>
                <filter name="filter_reconciled" string="Reconciled"
                    domain="[('is_reconciled','=',True)]"/>
                <filter name="filter_to_check" string="To Review"
                    domain="[('move_id.checked','=',False),('is_reconciled','=',False)]"/>
                <separator/>
                <filter name="filter_date" date="date" string="Date"/>
            </search>
        </field>
    </record>


    <record id="view_odooer_bank_statement_import_form" model="ir.ui.view">
        <field name="name">odooer.account.bank.statement.import.form</field>
        <field name="model">odooer.account.bank.statement.import</field>
        <field name="arch" type="xml">
            <form string="Import Bank Statement">
                <group>
                    <group string="File">
                        <field name="journal_id"/>
                        <field name="attachment" filename="attachment_name" widget="binary"/>
                        <field name="attachment_name" invisible="1"/>
                        <field name="file_type" readonly="1"/>
                        <field name="date_format"/>
                        <field name="decimal_separator"/>
                    </group>
                    <group string="Column Mapping">
                        <field name="col_date"/>
                        <field name="col_description"/>
                        <field name="col_amount"/>
                        <field name="col_debit"/>
                        <field name="col_credit"/>
                        <field name="col_balance"/>
                        <field name="col_ref"/>
                    </group>
                </group>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_odooer_bank_statement_import" model="ir.actions.act_window">
        <field name="name">Import Bank Statement</field>
        <field name="res_model">odooer.account.bank.statement.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_odooer_bank_import"
        name="Import Bank Statement"
        parent="account.menu_finance_entries"
        action="action_odooer_bank_statement_import"
        sequence="50"/>
</odoo>
