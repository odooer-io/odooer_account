<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════════════════
         Aged Payable  — outstanding vendor balances by due-date bucket
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="account_report_aged_pay" model="account.report">
        <field name="name">Aged Payable</field>
        <field name="sequence">70</field>
        <field name="filter_date_range" eval="False"/>
        <field name="filter_show_draft" eval="True"/>
        <field name="filter_unfold_all" eval="False"/>
        <field name="filter_hide_0_lines">optional</field>
        <field name="availability_condition">always</field>
        <field name="default_opening_date_filter">today</field>
        <field name="load_more_limit">80</field>
    </record>

    <record id="account_report_ap_col_balance" model="account.report.column">
        <field name="report_id" ref="account_report_aged_pay"/>
        <field name="name">Balance</field>
        <field name="expression_label">balance</field>
        <field name="figure_type">monetary</field>
        <field name="sequence">10</field>
    </record>

    <record id="ap_line_all" model="account.report.line">
        <field name="name">Vendors</field>
        <field name="report_id" ref="account_report_aged_pay"/>
        <field name="sequence">10</field>
        <field name="code">AP_ALL</field>
        <field name="groupby">partner_id</field>
        <field name="foldable" eval="True"/>
        <field name="hide_if_zero" eval="True"/>
    </record>
    <record id="ap_expr_all_balance" model="account.report.expression">
        <field name="report_line_id" ref="ap_line_all"/>
        <field name="label">balance</field>
        <field name="engine">domain</field>
        <field name="formula">[('account_id.account_type', '=', 'liability_payable'), ('reconciled', '=', False)]</field>
        <field name="subformula">sum</field>
        <field name="figure_type">monetary</field>
    </record>
</odoo>
