<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════════════════
         Profit & Loss
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="account_report_pl" model="account.report">
        <field name="name">Profit &amp; Loss</field>
        <field name="sequence">10</field>
        <field name="filter_date_range" eval="True"/>
        <field name="filter_period_comparison" eval="True"/>
        <field name="filter_show_draft" eval="True"/>
        <field name="filter_unfold_all" eval="False"/>
        <field name="filter_hide_0_lines">optional</field>
        <field name="availability_condition">always</field>
        <field name="default_opening_date_filter">this_year</field>
        <field name="load_more_limit">80</field>
    </record>

    <record id="account_report_pl_col_balance" model="account.report.column">
        <field name="report_id" ref="account_report_pl"/>
        <field name="name">Balance</field>
        <field name="expression_label">balance</field>
        <field name="figure_type">monetary</field>
        <field name="sequence">10</field>
    </record>

    <!-- Income -->
    <record id="pl_line_income" model="account.report.line">
        <field name="name">Income</field>
        <field name="report_id" ref="account_report_pl"/>
        <field name="sequence">10</field>
        <field name="code">PL_INCOME</field>
        <field name="foldable" eval="True"/>
        <field name="hide_if_zero" eval="False"/>
        <!-- Clear old account_codes expression so domain expression can be created -->
        <field name="account_codes_formula" eval="False"/>
    </record>
    <record id="pl_expr_income_balance" model="account.report.expression">
        <field name="report_line_id" ref="pl_line_income"/>
        <field name="label">balance</field>
        <field name="engine">domain</field>
        <field name="formula">[('account_id.account_type', 'in', ['income', 'income_other'])]</field>
        <field name="subformula">-sum</field>
        <field name="figure_type">monetary</field>
    </record>

    <!-- Cost of Revenue -->
    <record id="pl_line_cogs" model="account.report.line">
        <field name="name">Cost of Revenue</field>
        <field name="report_id" ref="account_report_pl"/>
        <field name="sequence">20</field>
        <field name="code">PL_COGS</field>
        <field name="foldable" eval="True"/>
        <field name="hide_if_zero" eval="False"/>
        <field name="account_codes_formula" eval="False"/>
    </record>
    <record id="pl_expr_cogs_balance" model="account.report.expression">
        <field name="report_line_id" ref="pl_line_cogs"/>
        <field name="label">balance</field>
        <field name="engine">domain</field>
        <field name="formula">[('account_id.account_type', '=', 'expense_direct_cost')]</field>
        <field name="subformula">sum</field>
        <field name="figure_type">monetary</field>
    </record>

    <!-- Gross Profit -->
    <record id="pl_line_gross_profit" model="account.report.line">
        <field name="name">Gross Profit</field>
        <field name="report_id" ref="account_report_pl"/>
        <field name="sequence">30</field>
        <field name="code">PL_GROSS</field>
        <field name="foldable" eval="False"/>
        <field name="hide_if_zero" eval="False"/>
        <field name="aggregation_formula" eval="False"/>
    </record>
    <record id="pl_expr_gross_profit_balance" model="account.report.expression">
        <field name="report_line_id" ref="pl_line_gross_profit"/>
        <field name="label">balance</field>
        <field name="engine">aggregation</field>
        <field name="formula">PL_INCOME.balance - PL_COGS.balance</field>
        <field name="figure_type">monetary</field>
    </record>

    <!-- Operating Expenses -->
    <record id="pl_line_opex" model="account.report.line">
        <field name="name">Operating Expenses</field>
        <field name="report_id" ref="account_report_pl"/>
        <field name="sequence">40</field>
        <field name="code">PL_OPEX</field>
        <field name="foldable" eval="True"/>
        <field name="hide_if_zero" eval="False"/>
        <field name="account_codes_formula" eval="False"/>
    </record>
    <record id="pl_expr_opex_balance" model="account.report.expression">
        <field name="report_line_id" ref="pl_line_opex"/>
        <field name="label">balance</field>
        <field name="engine">domain</field>
        <field name="formula">[('account_id.account_type', 'in', ['expense', 'expense_other', 'expense_depreciation'])]</field>
        <field name="subformula">sum</field>
        <field name="figure_type">monetary</field>
    </record>

    <!-- Operating Income -->
    <record id="pl_line_operating_income" model="account.report.line">
        <field name="name">Operating Income</field>
        <field name="report_id" ref="account_report_pl"/>
        <field name="sequence">50</field>
        <field name="code">PL_OPINC</field>
        <field name="foldable" eval="False"/>
        <field name="hide_if_zero" eval="False"/>
        <field name="aggregation_formula" eval="False"/>
    </record>
    <record id="pl_expr_operating_income_balance" model="account.report.expression">
        <field name="report_line_id" ref="pl_line_operating_income"/>
        <field name="label">balance</field>
        <field name="engine">aggregation</field>
        <field name="formula">PL_GROSS.balance - PL_OPEX.balance</field>
        <field name="figure_type">monetary</field>
    </record>

    <!-- Other Income / Expense -->
    <record id="pl_line_other" model="account.report.line">
        <field name="name">Other Income / Expense</field>
        <field name="report_id" ref="account_report_pl"/>
        <field name="sequence">60</field>
        <field name="code">PL_OTHER</field>
        <field name="foldable" eval="True"/>
        <field name="hide_if_zero" eval="True"/>
        <field name="account_codes_formula" eval="False"/>
    </record>
    <record id="pl_expr_other_balance" model="account.report.expression">
        <field name="report_line_id" ref="pl_line_other"/>
        <field name="label">balance</field>
        <field name="engine">domain</field>
        <field name="formula">[('account_id.account_type', '=', 'income_other')]</field>
        <field name="subformula">-sum</field>
        <field name="figure_type">monetary</field>
    </record>

    <!-- Net Profit / Loss -->
    <record id="pl_line_net" model="account.report.line">
        <field name="name">Net Profit / Loss</field>
        <field name="report_id" ref="account_report_pl"/>
        <field name="sequence">70</field>
        <field name="code">PL_NET</field>
        <field name="foldable" eval="False"/>
        <field name="hide_if_zero" eval="False"/>
        <field name="aggregation_formula" eval="False"/>
    </record>
    <record id="pl_expr_net_balance" model="account.report.expression">
        <field name="report_line_id" ref="pl_line_net"/>
        <field name="label">balance</field>
        <field name="engine">aggregation</field>
        <field name="formula">PL_OPINC.balance + PL_OTHER.balance</field>
        <field name="figure_type">monetary</field>
    </record>
</odoo>
