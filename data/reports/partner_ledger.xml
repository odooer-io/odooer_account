<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════════════════
         Partner Ledger  — Receivable and Payable accounts grouped by partner
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="account_report_partner_ledger" model="account.report">
        <field name="name">Partner Ledger</field>
        <field name="sequence">50</field>
        <field name="filter_date_range" eval="True"/>
        <field name="filter_show_draft" eval="True"/>
        <field name="filter_unfold_all" eval="False"/>
        <field name="filter_hide_0_lines">optional</field>
        <field name="availability_condition">always</field>
        <field name="default_opening_date_filter">this_year</field>
        <field name="load_more_limit">80</field>
    </record>

    <record id="account_report_pl2_col_debit" model="account.report.column">
        <field name="report_id" ref="account_report_partner_ledger"/>
        <field name="name">Debit</field>
        <field name="expression_label">debit</field>
        <field name="figure_type">monetary</field>
        <field name="sequence">10</field>
    </record>

    <record id="account_report_pl2_col_credit" model="account.report.column">
        <field name="report_id" ref="account_report_partner_ledger"/>
        <field name="name">Credit</field>
        <field name="expression_label">credit</field>
        <field name="figure_type">monetary</field>
        <field name="sequence">20</field>
    </record>

    <record id="account_report_pl2_col_balance" model="account.report.column">
        <field name="report_id" ref="account_report_partner_ledger"/>
        <field name="name">Balance</field>
        <field name="expression_label">balance</field>
        <field name="figure_type">monetary</field>
        <field name="sequence">30</field>
    </record>

    <!-- Partners with AR/AP accounts -->
    <record id="pld_line_all" model="account.report.line">
        <field name="name">All Partners</field>
        <field name="report_id" ref="account_report_partner_ledger"/>
        <field name="sequence">10</field>
        <field name="code">PLD_ALL</field>
        <field name="groupby">partner_id</field>
        <field name="foldable" eval="True"/>
        <field name="hide_if_zero" eval="False"/>
    </record>
    <record id="pld_expr_all_debit" model="account.report.expression">
        <field name="report_line_id" ref="pld_line_all"/>
        <field name="label">debit</field>
        <field name="engine">domain</field>
        <field name="formula">[('account_id.account_type', 'in', ['asset_receivable', 'liability_payable'])]</field>
        <field name="subformula">debit</field>
        <field name="figure_type">monetary</field>
    </record>
    <record id="pld_expr_all_credit" model="account.report.expression">
        <field name="report_line_id" ref="pld_line_all"/>
        <field name="label">credit</field>
        <field name="engine">domain</field>
        <field name="formula">[('account_id.account_type', 'in', ['asset_receivable', 'liability_payable'])]</field>
        <field name="subformula">credit</field>
        <field name="figure_type">monetary</field>
    </record>
    <record id="pld_expr_all_balance" model="account.report.expression">
        <field name="report_line_id" ref="pld_line_all"/>
        <field name="label">balance</field>
        <field name="engine">domain</field>
        <field name="formula">[('account_id.account_type', 'in', ['asset_receivable', 'liability_payable'])]</field>
        <field name="subformula">sum</field>
        <field name="figure_type">monetary</field>
    </record>
</odoo>
